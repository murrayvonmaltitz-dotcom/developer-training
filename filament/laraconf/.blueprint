created:
    - database/factories/ConferenceFactory.php
    - database/factories/VenueFactory.php
    - database/factories/SpeakerFactory.php
    - database/factories/TalkFactory.php
    - database/migrations/2026_04_02_064818_create_conferences_table.php
    - database/migrations/2026_04_02_064819_create_venues_table.php
    - database/migrations/2026_04_02_064820_create_speakers_table.php
    - database/migrations/2026_04_02_064821_create_talks_table.php
    - database/migrations/2026_04_02_064822_create_conference_speaker_table.php
    - database/migrations/2026_04_02_064823_create_conference_talk_table.php
    - app/Models/Conference.php
    - app/Models/Venue.php
    - app/Models/Speaker.php
    - app/Models/Talk.php
models:
    User: { name: string, email: string, email_verified_at: 'timestamp nullable', password: string, remember_token: 'string:100 nullable' }
    Conference: { name: string, description: string, start_date: datetime, end_date: datetime, status: string, region: string, venue_id: 'id foreign nullable', relationships: { belongsTo: Venue, belongsToMany: 'Speaker, Talk' } }
    Venue: { name: string, city: string, country: string, postal_code: string, relationships: { hasMany: Conference } }
    Speaker: { name: string, email: string, bio: text, twitter_handle: string, relationships: { belongsToMany: Conference } }
    Talk: { title: string, abstract: text, speaker_id: 'id foreign', relationships: { belongsTo: Speaker, belongsToMany: Conference } }
